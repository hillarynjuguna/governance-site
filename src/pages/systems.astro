---
import Layout from '@/components/layout/Layout.astro';
---

<Layout
  title="AI Architecture & Governance Frameworks"
  description="The architectural patterns, design methodologies, and infrastructural specifications underlying the governance stack."
>
  <!-- Hero -->
  <section class="pt-20 pb-12">
    <div class="mx-auto max-w-container px-6">
      <h1 class="font-display text-4xl sm:text-5xl text-text-primary">
        AI Architecture &amp; Governance Frameworks
      </h1>
      <p class="text-lg text-text-secondary mt-4 max-w-2xl leading-relaxed">
        The architectural patterns, design methodologies, and infrastructural specifications underlying the governance stack.
      </p>
    </div>
  </section>

  <!-- Architecture Sections -->
  <section class="py-12">
    <div class="mx-auto max-w-container px-6 flex flex-col gap-8">
      {[
        {
          title: 'CIR Constitutional Audit Architecture',
          items: [
            'Two-stage pipeline: LLM interpretation then deterministic Boolean scoring',
            'Four primitive evaluation matrix',
            'Provider-agnostic design (Anthropic, Gemini, Mistral)',
            'Separation of model interpretation from constitutional authority',
          ],
        },
        {
          title: 'RSPS Multi-Model Orchestration',
          items: [
            'Six-node architecture: tau-node (human sovereign) + phi, lambda, mu, gamma, rho',
            'Intelligence as relational field; emerges from node interactions, not from any single model',
            'Human sovereign as unconditional verification layer',
            'Structural principles evaluated by CIR',
          ],
        },
        {
          title: 'Governed Execution Layer',
          items: [
            'Boundary Governance Case (BGC) Schema',
            'Governance Invariants at execution seam',
            'Prevention of failures at the AI model / real-world system interface',
          ],
        },
        {
          title: 'Provenance Infrastructure',
          items: [
            'ProvenanceIdSchema / ProvenanceEnvelope TypeScript definitions',
            'Data contract layer for verifiable intelligence lineage',
            'Audit trail architecture for AI lifecycle accountability',
          ],
        },
        {
          title: 'Writ: RAG Knowledge Enforcement',
          items: [
            'Five-stage pipeline: BM25 + vector + graph traversal + RRF ranking',
            'Rule enforcement for AI coding agents',
            'Knowledge delivery with constitutional constraints',
          ],
        },
      ].map((section) => (
        <details class="group rounded-lg border border-border-subtle bg-surface overflow-hidden">
          <summary class="flex items-center justify-between p-5 cursor-pointer list-none hover:bg-surface-raised transition-colors">
            <h3 class="font-body text-base font-semibold text-text-primary">{section.title}</h3>
            <svg class="h-5 w-5 text-text-muted transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2}>
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-5 pb-5">
            <ul class="flex flex-col gap-2">
              {section.items.map((item) => (
                <li class="flex items-start gap-3 text-sm text-text-secondary">
                  <span class="text-accent mt-1 flex-shrink-0">&#8226;</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </details>
      ))}
    </div>
  </section>
</Layout>
