---
import Layout from '@/components/layout/Layout.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('core', 'known-failure-corpus');
const { Content } = entry ? await entry.render() : { Content: () => null };
---

<Layout
  title="Known Failure Corpus | Oscillatory Fields"
  description="Calibration cases used to verify the CIR Diagnostic Engine's classification accuracy across real-world governance failure incidents."
>
  <div class="pt-28 pb-24 max-w-4xl mx-auto px-6">
    <!-- Header -->
    <div class="mb-12">
      <span class="font-mono text-xs tracking-wider text-accent uppercase">CIR Diagnostic Engine · Calibration Dataset</span>
      <h1 class="text-4xl sm:text-5xl font-display text-text-primary mt-3 mb-4 leading-tight">
        Known Failure Corpus
      </h1>
      <p class="text-xl text-text-secondary max-w-2xl">
        Real incidents with known governance classifications. Public falsification evidence that the four CIR primitives compress real-world failures across domains.
      </p>
      <div class="flex flex-wrap items-center gap-6 mt-6 pt-6 border-t border-white/10">
        <a
          href="https://cir-diagnostic-engine.vercel.app"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-accent px-5 py-2.5 text-sm font-semibold text-text-inverse transition-opacity hover:opacity-90"
        >
          Run the CIR Diagnostic
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
        <a href="/governed-intelligence" class="text-sm text-text-muted hover:text-text-secondary transition-colors">
          Governance Stack →
        </a>
      </div>
    </div>

    <!-- Content -->
    <div class="prose prose-invert prose-lg max-w-none
      prose-headings:font-display prose-headings:font-normal prose-headings:scroll-mt-28
      prose-h2:text-2xl prose-h2:mt-14 prose-h2:mb-4 prose-h2:border-b prose-h2:border-white/10 prose-h2:pb-3
      prose-h3:text-lg prose-h3:mt-8 prose-h3:mb-3 prose-h3:text-accent
      prose-p:text-text-secondary prose-p:leading-relaxed
      prose-strong:text-white
      prose-code:text-accent prose-code:bg-surface prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm
      prose-hr:border-white/10
      prose-ul:text-text-secondary
      prose-li:marker:text-accent
    ">
      {entry ? <Content /> : <p>Content not found.</p>}
    </div>

    <!-- Footer nav -->
    <div class="mt-20 pt-8 border-t border-white/10 flex flex-wrap items-center justify-between gap-4">
      <a href="/cir-diagnostic-engine" class="text-sm text-text-muted hover:text-text-secondary transition-colors flex items-center gap-1">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
        CIR Diagnostic Engine
      </a>
      <a href="/bainbridge-warning" class="text-sm text-text-muted hover:text-text-secondary transition-colors">
        The Bainbridge Warning →
      </a>
    </div>
  </div>
</Layout>
