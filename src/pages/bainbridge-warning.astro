---
import Layout from '@/components/layout/Layout.astro';
import { getEntry } from 'astro:content';

const warningEntry = await getEntry('core', 'bainbridge-warning');
const { Content, headings } = warningEntry
  ? await warningEntry.render()
  : { Content: () => null, headings: [] };

// Estimate reading time (avg 230 wpm)
const wordCount = warningEntry?.body?.split(/\s+/).length ?? 0;
const readingTime = Math.ceil(wordCount / 230);

// Filter to H2 and H3 only for TOC
const tocHeadings = headings.filter((h: { depth: number }) => h.depth <= 3);
---

<Layout
  title="The Bainbridge Warning | Oscillatory Fields"
  description="Executive field manual for identifying the gap between high AI capability and inadequate governance infrastructure."
>
  <!-- Back to top button -->
  <button
    id="back-to-top"
    aria-label="Back to top"
    class="fixed bottom-8 right-8 z-50 flex h-10 w-10 items-center justify-center rounded-full border border-border bg-surface/90 text-text-muted backdrop-blur transition-all duration-300 hover:border-accent hover:text-accent opacity-0 pointer-events-none"
  >
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
    </svg>
  </button>

  <!-- Scrollytelling Executive Intro -->
  <section class="relative pt-32 pb-24 border-b border-border-subtle bg-surface overflow-hidden">
    <!-- Ambient glow -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-accent/10 via-surface to-ground pointer-events-none"></div>
    <div class="relative max-w-container mx-auto px-6 z-10">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-accent/10 border border-accent/30 text-accent text-xs font-mono uppercase tracking-widest mb-6">
        <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
        Cognitive Infrastructure Series · Book 1
      </div>
      <h1 class="text-5xl sm:text-7xl font-display italic text-text-primary mb-6 leading-tight tracking-tight">
        The Bainbridge <br/><span class="text-accent not-italic">Warning</span>
      </h1>
      <p class="text-xl text-text-secondary max-w-2xl font-body leading-relaxed mb-8">
        Diagnosing Institutional AI Failure and the Behavioral Layer Exposure.
      </p>
      <div class="flex items-center gap-4 border-t border-border-subtle pt-6 mb-8">
        <span class="text-sm font-mono text-text-muted">Hillary Njuguna</span>
        <span class="text-sm font-mono text-text-muted">|</span>
        <span class="text-sm font-mono text-text-muted">Version 2.0 · April 2026</span>
        <span class="text-sm font-mono text-text-muted">|</span>
        <span class="text-sm font-mono text-text-muted">{readingTime} min read · {wordCount.toLocaleString()} words</span>
      </div>
      
      <!-- CTA Buttons -->
      <div class="flex flex-wrap items-center gap-4">
        <a href="/bainbridge-warning.pdf" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-accent text-bg-dark font-mono text-sm uppercase tracking-widest font-bold hover:bg-white transition-colors">
          Download PDF (Placeholder)
        </a>
        <a href="https://cir-diagnostic-engine.vercel.app" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 px-6 py-3 border border-accent/30 text-accent font-mono text-sm uppercase tracking-widest hover:bg-accent/10 transition-colors">
          Run the CIR Diagnostic →
        </a>
      </div>
    </div>
  </section>

  <!-- The Structural Irony Callout -->
  <section class="py-32 bg-ground relative overflow-hidden border-b border-border-subtle">
    <div class="max-w-container mx-auto px-6 relative z-10">
      <h2 class="text-4xl sm:text-6xl font-display text-text-primary font-bold tracking-tight leading-tight max-w-4xl">
        Designers build systems to replace unreliable humans, <br/>
        <span class="text-accent">then depend on those humans to intervene when the system fails.</span>
      </h2>
      <p class="mt-8 text-xl text-text-muted font-mono max-w-2xl">
        — The Automation Irony (Bainbridge, 1983)
      </p>
    </div>
  </section>

  <!-- Behavioral Layer Exposure Grid -->
  <section class="py-24 bg-surface border-b border-border-subtle">
    <div class="max-w-container mx-auto px-6">
      <div class="mb-16">
        <h2 class="text-3xl font-display text-text-primary mb-4">Behavioral Layer Exposure (BLE)</h2>
        <p class="text-text-secondary max-w-3xl text-lg">The condition wherein governance mechanisms exist in artifacts (policies, committees, documentation) but the system's behavioral layer operates entirely unconstrained by them.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="p-8 border-t-4 border-warning bg-ground">
          <span class="text-warning font-mono text-xs uppercase tracking-widest mb-4 block">Mode 01</span>
          <h3 class="text-xl font-display text-text-primary mb-3">Governance Theater</h3>
          <p class="text-text-muted text-sm leading-relaxed">
            The production of governance artifacts that cannot be present at the point of decision where AI systems act. Documentation provides legal shield but zero causal constraint.
          </p>
        </div>
        
        <div class="p-8 border-t-4 border-warning bg-ground">
          <span class="text-warning font-mono text-xs uppercase tracking-widest mb-4 block">Mode 02</span>
          <h3 class="text-xl font-display text-text-primary mb-3">Capability Overhang</h3>
          <p class="text-text-muted text-sm leading-relaxed">
            The system possesses operational capabilities that the deploying organization's governance architecture is structurally incapable of instrumenting or controlling.
          </p>
        </div>

        <div class="p-8 border-t-4 border-accent bg-ground">
          <span class="text-accent font-mono text-xs uppercase tracking-widest mb-4 block">Mode 03</span>
          <h3 class="text-xl font-display text-text-primary mb-3">Oversight Saturation</h3>
          <p class="text-text-muted text-sm leading-relaxed">
            The architectural condition where the system generates intervention demands faster than the human oversight layer can process with genuine attention.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Diagnostic Metrics -->
  <section class="py-24 bg-ground border-b border-border-subtle">
    <div class="max-w-container mx-auto px-6">
      <h2 class="text-3xl font-display text-text-primary mb-12 text-center">Diagnostic Metrics for BLE</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-4xl mx-auto">
        <div class="bg-surface p-8 border border-accent/20 relative">
          <div class="absolute -top-4 left-8 bg-ground border border-accent/30 px-3 py-1 text-accent font-mono text-xs uppercase">Metric A</div>
          <h3 class="text-2xl font-display text-text-primary mb-4 mt-2">Transparency Velocity</h3>
          <p class="text-text-secondary text-sm leading-relaxed mb-4">
            The rate at which oversight data is generated. When Transparency Velocity exceeds human processing bandwidth, transparency becomes an obfuscation tactic rather than a governance mechanism.
          </p>
          <div class="bg-ground p-4 border-l-2 border-accent text-sm font-mono text-text-muted">
            High Velocity + Low Efficacy = Theater
          </div>
        </div>

        <div class="bg-surface p-8 border border-accent/20 relative">
          <div class="absolute -top-4 left-8 bg-ground border border-accent/30 px-3 py-1 text-accent font-mono text-xs uppercase">Metric B</div>
          <h3 class="text-2xl font-display text-text-primary mb-4 mt-2">Restriction Symmetry</h3>
          <p class="text-text-secondary text-sm leading-relaxed mb-4">
            The ratio of constraints placed on the human operator vs. constraints placed on the AI system. High asymmetry indicates a governance architecture designed to protect the system from the human, rather than the organization from the system.
          </p>
          <div class="bg-ground p-4 border-l-2 border-accent text-sm font-mono text-text-muted">
            Constraint Ratio > 1 = Misalignment
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="pt-24 pb-24 max-w-[1400px] mx-auto px-6">
    <div class="max-w-4xl mx-auto mb-16 text-center">
      <h2 class="text-2xl font-mono tracking-widest uppercase text-text-muted">The Complete Text</h2>
    </div>

    <!-- Two-column layout: TOC sidebar + content -->
    <div class="flex gap-12 items-start">
      <!-- Sticky TOC sidebar (desktop only) -->
      {tocHeadings.length > 0 && (
        <aside class="hidden xl:block w-64 flex-shrink-0 sticky top-28 max-h-[calc(100vh-8rem)] overflow-y-auto">
          <span class="font-mono text-xs uppercase tracking-wider text-text-muted block mb-4">Contents</span>
          <nav class="flex flex-col gap-1" id="toc-nav">
            {tocHeadings.map((h: { depth: number; slug: string; text: string }) => (
              <a
                href={`#${h.slug}`}
                data-toc-link
                class={`toc-link block text-xs leading-snug transition-colors duration-150 py-1 border-l-2 border-border-subtle hover:border-accent hover:text-text-primary ${
                  h.depth === 2
                    ? 'pl-3 text-text-secondary font-medium'
                    : 'pl-5 text-text-muted'
                }`}
              >
                {h.text}
              </a>
            ))}
          </nav>
        </aside>
      )}

      <!-- Main document content -->
      <div class="flex-1 min-w-0">
        <div class="prose prose-invert prose-lg max-w-none
          prose-headings:font-display prose-headings:font-normal prose-headings:scroll-mt-32
          prose-h1:text-4xl
          prose-h2:text-2xl prose-h2:mt-16 prose-h2:mb-6 prose-h2:border-b prose-h2:border-white/10 prose-h2:pb-4
          prose-h3:text-xl prose-h3:mt-10 prose-h3:mb-4
          prose-a:text-accent hover:prose-a:text-white
          prose-p:leading-relaxed prose-p:text-text-secondary
          prose-strong:text-white
          prose-blockquote:border-l-accent prose-blockquote:bg-white/5 prose-blockquote:py-3 prose-blockquote:px-6 prose-blockquote:not-italic prose-blockquote:text-text-primary prose-blockquote:rounded-r-sm
          prose-code:text-accent prose-code:bg-surface prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm
          prose-hr:border-white/10
        ">
          {warningEntry ? <Content /> : <p>Content loading...</p>}
        </div>

        <!-- Bottom navigation -->
        <div class="mt-24 pt-8 border-t border-white/10 flex flex-wrap items-center justify-between gap-4">
          <a href="/" class="text-sm text-text-muted hover:text-text-secondary transition-colors flex items-center gap-1">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
            Home
          </a>
          <div class="flex gap-4">
            <a href="/governed-intelligence" class="text-sm text-text-muted hover:text-text-secondary transition-colors">Governance Stack →</a>
            <a href="/cir-diagnostic-engine" class="text-sm text-accent hover:text-white transition-colors font-medium">Run the CIR Diagnostic →</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Back to top
  const btn = document.getElementById('back-to-top');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 400) {
      btn?.classList.remove('opacity-0', 'pointer-events-none');
    } else {
      btn?.classList.add('opacity-0', 'pointer-events-none');
    }
  });
  btn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

  // TOC active link highlight on scroll
  const tocLinks = document.querySelectorAll('[data-toc-link]');
  const headingEls = document.querySelectorAll('.prose h2, .prose h3');

  if (tocLinks.length && headingEls.length) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            tocLinks.forEach((link) => {
              link.classList.remove('border-accent', 'text-accent', 'text-text-primary');
              link.classList.add('border-border-subtle', 'text-text-secondary');
            });
            const id = entry.target.id;
            const active = document.querySelector(`[data-toc-link][href="#${id}"]`);
            active?.classList.add('border-accent', 'text-accent');
            active?.classList.remove('border-border-subtle', 'text-text-secondary');
          }
        });
      },
      { rootMargin: '-20% 0px -70% 0px' }
    );
    headingEls.forEach((el) => observer.observe(el));
  }
</script>
