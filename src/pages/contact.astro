---
import Layout from '@/components/layout/Layout.astro';
---

<Layout
  title="Connect"
  description="For collaboration, consulting, institutional engagement, or practitioner training inquiries."
>
  <!-- Hero -->
  <section class="pt-20 pb-12">
    <div class="mx-auto max-w-container px-6">
      <h1 class="font-display text-4xl sm:text-5xl text-text-primary">
        Connect.
      </h1>
      <p class="text-lg text-text-secondary mt-4 max-w-xl leading-relaxed">
        For collaboration, consulting, institutional engagement, or practitioner training inquiries.
      </p>
    </div>
  </section>

  <!-- Contact Form + Info -->
  <section class="py-12">
    <div class="mx-auto max-w-container px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Form -->
        <form class="flex flex-col gap-5" action="/contact" method="POST">
          <div class="flex flex-col gap-2">
            <label for="name" class="text-sm font-medium text-text-primary">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 rounded-md border border-border-subtle bg-surface text-text-primary text-sm focus:border-accent focus:outline-none transition-colors"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label for="email" class="text-sm font-medium text-text-primary">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 rounded-md border border-border-subtle bg-surface text-text-primary text-sm focus:border-accent focus:outline-none transition-colors"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label for="organization" class="text-sm font-medium text-text-primary">Organization (optional)</label>
            <input
              type="text"
              id="organization"
              name="organization"
              class="w-full px-4 py-3 rounded-md border border-border-subtle bg-surface text-text-primary text-sm focus:border-accent focus:outline-none transition-colors"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label for="inquiry" class="text-sm font-medium text-text-primary">Nature of inquiry</label>
            <select
              id="inquiry"
              name="inquiry"
              required
              class="w-full px-4 py-3 rounded-md border border-border-subtle bg-surface text-text-primary text-sm focus:border-accent focus:outline-none transition-colors appearance-none cursor-pointer"
            >
              <option value="">Select one</option>
              <option value="consulting">Consulting</option>
              <option value="collaboration">Collaboration</option>
              <option value="training">Training (Martha Course)</option>
              <option value="speaking">Speaking</option>
              <option value="general">General</option>
            </select>
          </div>

          <div class="flex flex-col gap-2">
            <label for="message" class="text-sm font-medium text-text-primary">Message</label>
            <textarea
              id="message"
              name="message"
              rows={5}
              required
              class="w-full px-4 py-3 rounded-md border border-border-subtle bg-surface text-text-primary text-sm focus:border-accent focus:outline-none transition-colors resize-vertical"
            />
          </div>

          <button
            type="submit"
            class="inline-flex items-center gap-2 self-start rounded-md bg-accent px-6 py-3 text-sm font-semibold text-text-inverse transition-opacity hover:opacity-90"
          >
            Send
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2}>
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </button>
        </form>

        <!-- Contact info -->
        <div class="flex flex-col gap-6">
          <div>
            <h3 class="font-mono text-xs text-text-muted uppercase mb-3">Direct</h3>
            <div class="flex flex-col gap-2">
              <a
                href="https://linkedin.com/in/hillarynjuguna"
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-text-secondary hover:text-text-primary transition-colors"
              >
                LinkedIn
              </a>
              <a
                href="https://github.com/hillarynjuguna"
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-text-secondary hover:text-text-primary transition-colors"
              >
                GitHub (hillarynjuguna)
              </a>
            </div>
          </div>

          <div>
            <h3 class="font-mono text-xs text-text-muted uppercase mb-3">Location</h3>
            <p class="text-sm text-text-secondary">
              Kuala Lumpur, Malaysia (UTC+8)
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  select option {
    background: var(--color-surface);
    color: var(--color-text-primary);
  }
</style>
