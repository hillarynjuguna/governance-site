---
const audiences = [
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>`,
    label: 'Creator',
    proposition: 'Quickly verify AI boundaries and constitutional alignment without friction.',
    cta: 'Quick Scan',
    href: 'https://cir-diagnostic-engine.vercel.app',
    layerColor: 'var(--color-layer-operational)',
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
    label: 'Founder',
    proposition: 'Perform a comprehensive architectural audit to ensure runtime control and scalability.',
    cta: 'Deep Diagnostic',
    href: 'https://cir-diagnostic-engine.vercel.app',
    layerColor: 'var(--color-layer-foundational)',
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`,
    label: 'Enterprise',
    proposition: 'Map systemic risks to compliance frameworks through the lens of structural governance.',
    cta: 'Regulatory Mapping',
    href: '/governed-intelligence',
    layerColor: 'var(--color-layer-infra)',
  },
];
---

<section class="py-24">
  <div class="mx-auto max-w-container px-6">
    <h2 class="font-display text-3xl sm:text-4xl italic text-text-primary mb-12">
      Governance for every layer.
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {audiences.map((a) => (
        <a
          href={a.href}
          class="group card-surface p-6 flex flex-col gap-4 transition-all duration-200 hover:-translate-y-0.5"
          style={`border-left: 2px solid ${a.layerColor};`}
        >
          <div class="flex items-center gap-3">
            <span class="text-accent" set:html={a.icon} />
            <h3 class="font-body text-lg font-semibold text-text-primary">{a.label}</h3>
          </div>
          <p class="text-sm text-text-secondary leading-relaxed flex-grow">
            {a.proposition}
          </p>
          <span class="inline-flex items-center gap-1 text-sm font-medium text-accent group-hover:gap-2 transition-all mt-auto">
            {a.cta}
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
