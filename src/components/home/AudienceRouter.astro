---
const audiences = [
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
    label: 'AI Startups & Founders',
    proposition: 'Operationalizing responsible AI for rapid, safe scaling.',
    cta: 'Run the Diagnostic',
    href: '/cir',
    layerColor: 'var(--color-layer-operational)',
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`,
    label: 'Governance Organizations',
    proposition: 'From abstract policy to demonstrable operational control.',
    cta: 'View the Stack',
    href: '/governance-stack',
    layerColor: 'var(--color-layer-foundational)',
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>`,
    label: 'AI Safety Labs / Research Orgs',
    proposition: 'From theory to runtime assurance; verified.',
    cta: 'Research & Systems',
    href: '/research',
    layerColor: 'var(--color-rsps)',
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>`,
    label: 'Technical Leadership',
    proposition: 'Architecting resilient AI infrastructure with integrated governance built in.',
    cta: 'Systems Architecture',
    href: '/systems',
    layerColor: 'var(--color-layer-infra)',
  },
];
---

<section class="py-24">
  <div class="mx-auto max-w-container px-6">
    <h2 class="font-display text-3xl sm:text-4xl italic text-text-primary mb-12">
      Start where you are.
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {audiences.map((a) => (
        <a
          href={a.href}
          class="group card-surface p-6 flex flex-col gap-4 transition-all duration-200 hover:-translate-y-0.5"
          style={`border-left: 2px solid ${a.layerColor};`}
        >
          <div class="flex items-center gap-3">
            <span class="text-accent" set:html={a.icon} />
            <h3 class="font-body text-lg font-semibold text-text-primary">{a.label}</h3>
          </div>
          <p class="text-sm text-text-secondary leading-relaxed">
            {a.proposition}
          </p>
          <span class="inline-flex items-center gap-1 text-sm font-medium text-accent group-hover:gap-2 transition-all">
            {a.cta}
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
