---
import { impactStories } from '@/data/impact-stories';
---

<section class="py-24">
  <div class="mx-auto max-w-container px-6">
    <h2 class="font-display text-3xl sm:text-4xl text-text-primary mb-12">
      Impact.
    </h2>

    <div class="flex lg:grid lg:grid-cols-3 gap-6 overflow-x-auto lg:overflow-visible pb-4 lg:pb-0 snap-x snap-mandatory">
      {impactStories.map((story) => (
        <div class="min-w-[300px] lg:min-w-0 flex flex-col gap-4 p-5 rounded-lg border border-border-subtle bg-surface snap-start">
          <!-- Layer tag -->
          <span
            class="layer-tag self-start"
            style={`color: ${story.layerColor}; border-color: ${story.layerColor};`}
          >
            {story.layer}
          </span>

          <h3 class="font-body text-lg font-semibold text-text-primary">
            {story.title}
          </h3>

          <div class="flex flex-col gap-3 text-sm leading-relaxed">
            <p class="text-text-secondary">
              <strong class="text-text-primary">Problem:</strong> {story.problem}
            </p>
            <div class="flex items-center gap-2">
              <span class="text-text-muted text-xs font-mono">Method:</span>
              <span class="framework-badge" style={`color: var(--color-cir); border-color: var(--color-cir);`}>
                {story.method}
              </span>
            </div>
            <p class="text-text-secondary">
              <strong class="text-text-primary">Outcome:</strong> {story.outcome}
            </p>
          </div>

          <a href={`/projects#${story.id}`} class="inline-flex items-center gap-1 text-sm font-medium text-accent mt-auto pt-2 hover:gap-2 transition-all">
            Read Case Study
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
