---
---

<section class="relative min-h-[92vh] grid-bg flex items-center overflow-hidden">
  <!-- Subtle gradient mesh background -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div
      class="absolute top-1/4 left-1/4 h-96 w-96 rounded-full opacity-[0.04]"
      style="background: radial-gradient(circle, var(--color-layer-foundational), transparent 70%);"
    />
    <div
      class="absolute bottom-1/4 right-1/3 h-80 w-80 rounded-full opacity-[0.04]"
      style="background: radial-gradient(circle, var(--color-accent), transparent 70%);"
    />
  </div>

  <div class="relative mx-auto max-w-container-wide px-6 py-20 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-center">
      <!-- Left: 60% -->
      <div class="lg:col-span-3 flex flex-col gap-6 animate-fade-in">
        <!-- Eyebrow -->
        <span class="font-mono text-sm tracking-wider text-accent uppercase">
          Oscillatory Fields / AI Governance Infrastructure
        </span>

        <!-- Headline -->
        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl xl:text-7xl text-text-primary leading-[1.1]">
          Governance Infrastructure<br />
          for AI Systems That<br />
          Have Consequences.
        </h1>

        <!-- Sub-headline -->
        <p class="text-lg text-text-secondary max-w-xl leading-relaxed">
          Constitutional design, runtime diagnostics, and orchestration architecture for human-AI systems. From theoretical primitives to deployed diagnostic tools.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap items-center gap-4 pt-2">
          <a
            href="/cir"
            class="inline-flex items-center gap-2 rounded-md bg-accent px-6 py-3 text-sm font-semibold text-text-inverse transition-all hover:opacity-90 hover:-translate-y-0.5"
          >
            Run the CIR Diagnostic
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="/governance-stack"
            class="inline-flex items-center gap-2 rounded-md border border-border px-6 py-3 text-sm font-medium text-text-secondary transition-all hover:text-text-primary hover:border-text-muted"
          >
            Explore the Governance Stack
          </a>
        </div>

        <!-- Framework badges -->
        <div class="flex flex-wrap items-center gap-3 pt-4 font-mono text-xs text-text-muted">
          <span>Deployed:</span>
          <a href="/governance-stack#operational" class="framework-badge transition-colors hover:text-accent" style="color: var(--color-cir); border-color: var(--color-cir);">
            CIR Diagnostic Engine
          </a>
          <span class="text-border">.</span>
          <a href="/governance-stack#foundational" class="framework-badge transition-colors hover:text-accent" style="color: var(--color-bainbridge); border-color: var(--color-bainbridge);">
            Bainbridge Warning
          </a>
          <span class="text-border">.</span>
          <a href="/governance-stack#infrastructural" class="framework-badge transition-colors hover:text-accent" style="color: var(--color-rsps); border-color: var(--color-rsps);">
            RSPS Architecture
          </a>
        </div>
      </div>

      <!-- Right: 40% -->
      <div class="hidden lg:flex lg:col-span-2 justify-center animate-slide-up" style="animation-delay: 0.2s;">
        <a href="/governance-stack" class="group relative">
          <div class="relative flex flex-col gap-1.5 p-4 rounded-lg border border-border-subtle bg-surface/50 transition-all duration-300 group-hover:border-border group-hover:bg-surface">
            <!-- Layer preview -->
            {[
              { label: 'Translational', color: 'var(--color-layer-translational)', width: '40%', items: 'martha-course' },
              { label: 'Operational', color: 'var(--color-layer-operational)', width: '70%', items: 'CIR, delta-instrument' },
              { label: 'Infrastructural', color: 'var(--color-layer-infra)', width: '55%', items: 'RSPS, CE-Ledger' },
              { label: 'Foundational', color: 'var(--color-layer-foundational)', width: '85%', items: 'premise, Bainbridge, sovereign-types' },
            ].map((layer) => (
              <div
                class="group/layer relative flex items-center gap-3 px-4 py-3 rounded border border-border-subtle bg-surface transition-all duration-200 group-hover/layer:border-opacity-50"
                style={{ borderLeftColor: layer.color, borderLeftWidth: '3px', borderLeftStyle: 'solid' }}
              >
                <span class="font-mono text-xs text-text-muted w-28 truncate">{layer.label}</span>
                <span class="font-mono text-[10px] text-text-muted truncate">{layer.items}</span>
              </div>
            ))}
          </div>
          <p class="mt-3 text-center font-mono text-xs text-text-muted group-hover:text-text-secondary transition-colors">
            View the full Governance Stack &rarr;
          </p>
        </a>
      </div>
    </div>
  </div>
</section>
