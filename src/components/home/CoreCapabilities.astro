---
import { capabilities } from '@/data/capabilities';
---

<section class="py-24 border-t border-border-subtle">
  <div class="mx-auto max-w-container px-6">
    <h2 class="font-display text-3xl sm:text-4xl text-text-primary mb-12">
      What the lab builds.
    </h2>

    <div class="flex lg:grid lg:grid-cols-5 gap-6 overflow-x-auto lg:overflow-visible pb-4 lg:pb-0 snap-x snap-mandatory">
      {capabilities.map((cap) => (
        <div class="min-w-[280px] lg:min-w-0 flex flex-col gap-4 p-5 rounded-lg border border-border-subtle bg-surface snap-start">
          <div class="text-accent">
            <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={cap.icon} />
            </svg>
          </div>
          <h3 class="font-body text-base font-semibold text-text-primary">{cap.title}</h3>
          <p class="text-sm text-text-secondary leading-relaxed">{cap.description}</p>
          <span
            class="framework-badge mt-auto self-start"
            style="color: var(--color-accent); border-color: var(--color-accent);"
          >
            {cap.framework}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
